{:tasks {doctor {:doc "Validate wiki pages against the schema"
                 :do [{:sh "python tools/check_wiki.py ."}]}
         viz    {:doc "Regenerate the OKF graph (viz.html)"
                 :do [{:sh "python tools/viz/render_viz.py . viz.html"}]}
         site   {:doc "Build the styled static site into site/"
                 :do [{:sh "python tools/build_site.py"}]}
         serve  {:doc "Local preview of the site"
                 :do [{:sh "python tools/build_site.py --serve"}]}
         enrich {:doc "Prepare the per-concept authoring manifest from a let-go checkout"
                 :do [{:sh "python -m tools.enrich.prepare --source-root ../let-go"}]}
         status {:doc "Report wiki authoring coverage vs the enrich manifest"
                 :do [{:sh "python -m tools.enrich.status"}]}
         next   {:doc "Generate authoring briefs for the next batch of pending concepts"
                 :do [{:sh "python -m tools.enrich.next --count 5"}]}}}
